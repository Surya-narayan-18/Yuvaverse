// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  STUDENT
}

enum RegistrationStatus {
  PENDING
  SUCCESS
  FAILED
}

enum ApplicationStatus {
  NEW
  SHORTLISTED
  INTERVIEWED
  RECRUITED
  REJECTED
}

// ─────────────────────────────────────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────────────────────────────────────

/// Platform users — admins manage events; students register for them.
model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(STUDENT)
  createdAt    DateTime @default(now())

  @@map("users")
}

/// An event hosted by the club.
model Event {
  id          String         @id @default(cuid())
  title       String
  description String         @db.Text
  date        DateTime
  venue       String
  price        Float          @default(0)
  imageUrl     String?
  bannerUrl    String?        // Cloudinary CDN URL for the event banner
  customFields Json?          // Array of required/optional dynamic questions per event

  // ── Group registration fields (all optional / defaulted — backward compat) ──
  eventType            String?   // Workshop | Hackathon | Competition | Seminar | Meetup
  maxTeamSize          Int       @default(1)   // 1 = individual event; >1 = team event
  maxRegistrations     Int?      // null = unlimited
  currentRegistrations Int       @default(0)   // denormalized counter (teams for group, individuals for solo)
  registrationDeadline DateTime? // optional custom deadline

  createdAt    DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  // Relations
  registrations Registration[]
  teams         Team[]

  @@map("events")
}

/// A student's registration record for a specific event.
model Registration {
  id                String             @id @default(cuid())
  studentName       String
  studentEmail      String
  collegeId         String             // Student's college/university ID number
  razorpayOrderId   String?            @unique
  razorpayPaymentId String?            @unique
  status            RegistrationStatus @default(PENDING)
  customAnswers     Json?              // Captured form inputs representing the 'customFields'
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  // Foreign key
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, studentEmail])  // One registration per email per event
  @@unique([eventId, collegeId])     // One registration per college ID per event
  @@index([studentEmail])
  @@map("registrations")
}

/// A team registration for a group event.
model Team {
  id                String     @id @default(cuid())
  eventId           String
  event             Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  teamName          String
  leaderName        String
  leaderEmail       String
  leaderPhone       String
  memberCount       Int        @default(1)
  status            String    @default("PENDING") // PENDING | SUCCESS | FAILED
  razorpayOrderId   String?    @unique
  razorpayPaymentId String?    @unique
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  members TeamMember[]

  @@index([leaderEmail])
  @@map("teams")
}

/// An individual member of a team registration.
model TeamMember {
  id     String @id @default(cuid())
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  name   String
  email  String

  @@map("team_members")
}

/// A recruitment application submitted via the "Join Us" page.
model Application {
  id            String   @id @default(cuid())
  name          String
  email         String
  phone         String
  roleAppliedFor String
  message       String?  @db.Text
  resumeLink    String?
  status        ApplicationStatus @default(NEW)
  createdAt     DateTime @default(now())

  @@index([email])
  @@map("applications")
}

/// A message submitted via the "Contact Us" page.
model ContactMessage {
  id          String   @id @default(cuid())
  senderName  String
  senderEmail String
  message     String   @db.Text
  createdAt   DateTime @default(now())

  @@index([senderEmail])
  @@map("contact_messages")
}
