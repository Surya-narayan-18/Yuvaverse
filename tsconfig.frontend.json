{
  "compilerOptions": {
    "target": "ES2020",
    "module": "None",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "outDir": "./src/public/js",
    "rootDir": "./src/public/ts",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/public/ts/**/*"],
  "exclude": ["node_modules", "dist", "src/server.ts", "src/config", "src/controllers", "src/middlewares", "src/routes", "src/utils", "src/validators", "src/mailers"]
}
